{
  "version": 3,
  "routes": [
    {
      "src": "^/(?:(.+)/)?index(?:\\.html)?/?$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308
    },
    {
      "src": "^/(.*)\\.html/?$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/decision-center$",
      "dest": "/api/decision-center",
      "check": true
    },
    {
      "src": "^/api/delay$",
      "dest": "/api/delay",
      "check": true
    },
    {
      "src": "^/api/financial$",
      "dest": "/api/financial",
      "check": true
    }
  ],
  "overrides": {}
}